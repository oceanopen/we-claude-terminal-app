{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "We Claude Terminal Monitor",
  "version": "0.0.3",
  "identifier": "com.we.claude.terminal.monitor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "publisher": "oceangao",
    "copyright": "Copyright (C) 2026 oceangao",
    "category": "Utility",
    "shortDescription": "We Claude Terminal Monitor Desktop App",
    "longDescription": "We Claude Terminal Monitor Desktop App",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
